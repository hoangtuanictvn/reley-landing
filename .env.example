# Public download URL for the Desktop app (e.g. R2 / S3 / GitHub release).
# When unset, CTAs fall back to the in-page #download anchor.
NEXT_PUBLIC_DOWNLOAD_URL=

# Optional webhook to forward waitlist signups to (Resend / Loops / ConvertKit
# / your own backend). When unset, /api/waitlist returns 200 and logs in dev.
WAITLIST_WEBHOOK_URL=
