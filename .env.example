# Platform-specific download URLs (R2 / S3 / GitHub release / etc).
# Leave blank for builds not yet shipped - the /download page will mark them
# as "Coming soon". The primary header Download CTA uses MAC_ARM by default.
NEXT_PUBLIC_DOWNLOAD_URL_MAC_ARM=
NEXT_PUBLIC_DOWNLOAD_URL_MAC_INTEL=
NEXT_PUBLIC_DOWNLOAD_URL_WIN=
NEXT_PUBLIC_DOWNLOAD_URL_LINUX=

# Legacy single download URL. Used as fallback when no platform-specific
# URL is set. Prefer the per-platform vars above.
NEXT_PUBLIC_DOWNLOAD_URL=

# Resend waitlist integration. Get a key + audience at https://resend.com.
# /api/waitlist calls resend.contacts.create to add the email to the audience.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
# Optional: send a confirmation email. Domain must be verified in Resend.
RESEND_FROM="Relay <hi@yourdomain.dev>"

# Generic webhook fallback. Used only when RESEND_API_KEY is unset (handy if
# you want to switch to Loops / ConvertKit / your own backend later).
WAITLIST_WEBHOOK_URL=
